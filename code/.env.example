# Sao chép file này thành .env và ĐỔI mọi giá trị trước khi deploy thật.
# docker-compose tự đọc code/.env. Nếu không có .env, hệ thống dùng default demo (KHÔNG an toàn).

# Postgres (dùng chung cho app + MLflow backend)
POSTGRES_PASSWORD=skin_pass

# MinIO (object storage: ảnh + DVC remote + MLflow artifacts)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Token bảo vệ các API /admin/* (control plane)
ADMIN_TOKEN=admin-secret

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
